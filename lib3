-- Drawing utilities
local function lerp(a, b, t)
    return a + (b - a) * t
end

local function clamp(x, min, max)
    if x < min then return min end
    if x > max then return max end
    return x
end

local function round(x)
    return math.floor(x + 0.5)
end

local function rgba(color, alpha)
    return Color3.new(color.R * alpha, color.G * alpha, color.B * alpha)
end

local function quad(t)
    return 1 - (1 - t) * (1 - t)
end

-- String width estimation
local char_widths = {}
for i = 32, 126 do
    char_widths[string.char(i)] = 0.5
end
char_widths['i'] = 0.3
char_widths['l'] = 0.3
char_widths['I'] = 0.4
char_widths[' '] = 0.4
char_widths['m'] = 0.7
char_widths['w'] = 0.7
char_widths['M'] = 0.8
char_widths['W'] = 0.8

local function str_width(str, font_size)
    font_size = font_size or UILib._font_size
    local width = 0
    for i = 1, #str do
        local char = str:sub(i, i)
        width = width + (char_widths[char] or 0.5)
    end
    return round(width * font_size)
end

-- Drawing creation
local function new_drawing(type, props)
    local d = Drawing.new(type)
    for k, v in pairs(props or {}) do
        d[k] = v
    end
    table.insert(UILib._drawings, d)
    return d
end

-- Menu functions
function UILib:SetMenuTitle(title)
    self._menu_title = title
end

function UILib:SetMenuSize(size)
    self._menu_size = size
end

function UILib:CenterMenu()
    local screen = workspace.CurrentCamera.ViewportSize
    self._menu_pos = Vector2.new(
        round((screen.X - self._menu_size.X) / 2),
        round((screen.Y - self._menu_size.Y) / 2)
    )
end

function UILib:Notification(text, duration)
    duration = duration or 4
    table.insert(self._notifications, {
        text = text,
        duration = duration,
        spawn_time = tick(),
        y_offset = 0,
    })
end

-- Tab creation
function UILib:Tab(name)
    if not self._tree[name] then
        self._tree[name] = { _items = {} }
        table.insert(self._tab_order, name)
    end
    
    return {
        Section = function(_, section_name)
            return {
                Toggle = function(_, title, default, callback)
                    local toggle = {
                        value = default,
                        title = title,
                        callback = callback,
                        keybind = nil,
                    }
                    table.insert(self._tree[name]._items, {
                        type = "toggle",
                        title = title,
                        value = default,
                        callback = callback,
                    })
                    
                    local toggle_obj = {
                        SetValue = function(_, v)
                            toggle.value = v
                            if callback then callback(v) end
                        end,
                        AddKeybind = function(_, default_key, name, toggle_mode, key_callback)
                            -- Store keybind info
                            toggle.keybind = {
                                key = default_key,
                                name = name,
                                toggle_mode = toggle_mode,
                                callback = key_callback,
                            }
                            return toggle_obj
                        end,
                    }
                    return toggle_obj
                end,
                
                Slider = function(_, title, default, min, max, step, suffix, callback)
                    table.insert(self._tree[name]._items, {
                        type = "slider",
                        title = title,
                        value = default,
                        min = min,
                        max = max,
                        step = step,
                        suffix = suffix,
                        callback = callback,
                    })
                    return {
                        SetValue = function(_, v)
                            if callback then callback(v) end
                        end,
                    }
                end,
                
                Button = function(_, title, callback)
                    table.insert(self._tree[name]._items, {
                        type = "button",
                        title = title,
                        callback = callback,
                    })
                    return {}
                end,
            }
        end,
    }
end

function UILib:CreateSettingsTab(name)
    local tab = self:Tab(name or "Settings")
    local section = tab:Section("Menu")
    
    return tab, section, {}
end

