    return key_map[key_id] or tostring(key_id):lower()
end

-- Main render loop
function UILib:Step()
    if self._unloaded then return end
    
    self._step = self._step + 1
    local now = tick()
    
    -- Toggle menu with F2
    if UserInputService:IsKeyDown(Enum.KeyCode.F2) then
        if now - self._menu_toggled_at > 0.3 then
            self._menu_open = not self._menu_open
            self._menu_toggled_at = now
        end
    end
    
    -- Simple drawing for notifications
    local notif_y = 20
    for i, notif in ipairs(self._notifications) do
        local age = now - notif.spawn_time
        if age < notif.duration then
            -- Draw notification (simplified)
            notif_y = notif_y + 40
        end
    end
    
    -- Clean up old notifications
    for i = #self._notifications, 1, -1 do
        if now - self._notifications[i].spawn_time > self._notifications[i].duration then
            table.remove(self._notifications, i)
        end
    end
end

function UILib:Unload()
    self._unloaded = true
    for _, d in ipairs(self._drawings) do
        pcall(function() d:Remove() end)
    end
    self._drawings = {}
end

function UILib:_FullWipe()
    self:Unload()
end

return UILib
