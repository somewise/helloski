-- Main step function
function UILib.Step(self)
    if self._unloaded then
        return
    end
    
    self._step = self._step + 1
    local now = tick()
    
    -- Toggle menu with F2
    if UserInputService:IsKeyDown(Enum.KeyCode.F2) then
        if now - self._menu_toggled_at > 0.3 then
            self._menu_open = not self._menu_open
            self._menu_toggled_at = now
        end
    end
    
    -- Clean up old notifications
    local notifications = self._notifications
    for i = #notifications, 1, -1 do
        local notif = notifications[i]
        if now - notif.spawn_time > notif.duration then
            table_remove(notifications, i)
        end
    end
end

-- Unload function
function UILib.Unload(self)
    self._unloaded = true
    local drawings = self._drawings
    for i = 1, #drawings do
        local d = drawings[i]
        pcall(function()
            d:Remove()
        end)
    end
    self._drawings = {}
end

function UILib._FullWipe(self)
    self:Unload()
end

