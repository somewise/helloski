-- Local drawing creation function
local function new_drawing(dtype, props)
    local d = Drawing_new(dtype)
    if props then
        for k, v in pairs(props) do
            d[k] = v
        end
    end
    table_insert(UILib._drawings, d)
    return d
end

-- Simple lerp function
local function lerp(a, b, t)
    return a + (b - a) * t
end

-- Simple clamp function
local function clamp(x, min, max)
    if x < min then return min end
    if x > max then return max end
    return x
end

-- String width calculation with cached char widths
local char_widths = {}
for i = 32, 126 do
    char_widths[string.char(i)] = 0.5
end
char_widths["i"] = 0.3
char_widths["l"] = 0.3
char_widths["I"] = 0.4
char_widths[" "] = 0.4
char_widths["m"] = 0.7
char_widths["w"] = 0.7
char_widths["M"] = 0.8
char_widths["W"] = 0.8

local function str_width(str, font_size)
    font_size = font_size or UILib._font_size
    local width = 0
    for i = 1, #str do
        local char = str:sub(i, i)
        width = width + (char_widths[char] or 0.5)
    end
    return math_floor(width * font_size)
end

-- Menu configuration functions
function UILib.SetMenuTitle(self, title)
    self._menu_title = title
end

function UILib.SetMenuSize(self, size)
    self._menu_size = size
end

function UILib.CenterMenu(self)
    local camera = workspace.CurrentCamera
    local screen = camera.ViewportSize
    self._menu_pos = Vector2_new(
        math_floor((screen.X - self._menu_size.X) / 2),
        math_floor((screen.Y - self._menu_size.Y) / 2)
    )
end

function UILib.Notification(self, text, duration)
    duration = duration or 4
    local notif = {}
    notif.text = text
    notif.duration = duration
    notif.spawn_time = tick()
    notif.y_offset = 0
    table_insert(self._notifications, notif)
end

-- Create tab function
function UILib.Tab(self, name)
    if not self._tree[name] then
        self._tree[name] = {}
        self._tree[name]._items = {}
        table_insert(self._tab_order, name)
    end
    
    local tab_obj = {}
    tab_obj._parent = self
    tab_obj._name = name
    
    function tab_obj.Section(_, section_name)
        local section_obj = {}
        section_obj._parent = tab_obj
        section_obj._name = section_name
        
        function section_obj.Toggle(_, title, default, callback)
            local item = {}
            item.type = "toggle"
            item.title = title
            item.value = default
            item.callback = callback
            item.keybind = nil
            table_insert(tab_obj._parent._tree[name]._items, item)
            
            local toggle_obj = {}
            
            function toggle_obj.SetValue(_, v)
                item.value = v
                if callback then
                    callback(v)
                end
            end
            
            function toggle_obj.AddKeybind(_, default_key, key_name, toggle_mode, key_callback)
                item.keybind = {}
                item.keybind.key = default_key
                item.keybind.name = key_name
                item.keybind.toggle_mode = toggle_mode
                item.keybind.callback = key_callback
                return toggle_obj
            end
            
            return toggle_obj
        end
        
        function section_obj.Slider(_, title, default, min, max, step, suffix, callback)
            local item = {}
            item.type = "slider"
            item.title = title
            item.value = default
            item.min = min
            item.max = max
            item.step = step
            item.suffix = suffix
            item.callback = callback
            table_insert(tab_obj._parent._tree[name]._items, item)
            
            local slider_obj = {}
            
            function slider_obj.SetValue(_, v)
                item.value = v
                if callback then
                    callback(v)
                end
            end
            
            return slider_obj
        end
        
        function section_obj.Button(_, title, callback)
            local item = {}
            item.type = "button"
            item.title = title
            item.callback = callback
            table_insert(tab_obj._parent._tree[name]._items, item)
            return {}
        end
        
        return section_obj
    end
    
    return tab_obj
end

function UILib.CreateSettingsTab(self, name)
    local tab = self:Tab(name or "Settings")
    local section = tab:Section("Menu")
    return tab, section, {}
end

