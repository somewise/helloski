local function lerp(a,b,t)    return a+(b-a)*t end
local function clamp(x,a,b)   if x>b then return b elseif x<a then return a else return x end end
local function lerpC(c1,c2,t) return Color3.new(lerp(c1.R,c2.R,t),lerp(c1.G,c2.G,t),lerp(c1.B,c2.B,t)) end
local function easeOut(t)      return 1-(1-t)*(1-t) end
local function getDictLen(d)   local i=0 for _ in pairs(d) do i=i+1 end return i end

local function fmtNum(v)
    if v==math.floor(v) then return tostring(math.floor(v)) end
    return (string.format("%.2f",v)):gsub("%.?0+$","")
end

local function rgbToHsv(r,g,b)
    local max,min=math.max(r,g,b),math.min(r,g,b)
    local h,s,v=0,0,max; local d=max-min
    if max~=0 then s=d/max end
    if d==0 then h=0 else
        if max==r then h=(g-b)/d; if g<b then h=h+6 end
        elseif max==g then h=(b-r)/d+2
        elseif max==b then h=(r-g)/d+4 end
        h=h/6
    end
    return h,s,v
end

-- ── Core helpers ──────────────────────────────────────────────────────────────
do
    function UILib:_KeyIDToName(id) for n,k in pairs(self._inputs) do if k.id==id then return n end end return nil end
    function UILib:_IsKeyPressed(k) return self._inputs[k].click end
    function UILib:_IsKeyHeld(k)    return self._inputs[k].held  end
    function UILib:_GetScreenSize()
        local ss=Vector2.new(1920,1080)
        local cam=workspace.CurrentCamera
        if cam and cam.ViewportSize then ss=cam.ViewportSize end
        return ss
    end
    function UILib:_GetMousePos()
        local mp=Vector2.new()
        local lp=game:GetService('Players').LocalPlayer
        if lp then local m=lp:GetMouse(); if m then mp=Vector2.new(m.X,m.Y) end end
        return mp
    end
    function UILib:_IsMouseWithinBounds(o,s)
        local m=self:_GetMousePos()
        return m.x>=o.x and m.x<=o.x+s.x and m.y>=o.y and m.y<=o.y+s.y
    end
    function UILib:_ApplyTheme(name) self._theme_name=name; self._theming=self._themes[name] or self._themes.Light end
end

-- ── Drawing ───────────────────────────────────────────────────────────────────
do
    function UILib:_GetTextBounds(text,fontFace,fontSize)
        fontFace=fontFace or self._font_face; fontSize=fontSize or self._font_size
        if fontFace==Drawing.Fonts.UI then return Vector2.new(#text*fontSize*0.53846,fontSize) end
        return Vector2.new(#text*fontSize*0.58,fontSize)
    end

    function UILib:_Draw(id,dt,dc,dz,...)
        local d=self._drawings[id]
        if dt=='rect' then
            if not d then self._drawings[id]=Drawing.new('Square'); return self:_Draw(id,dt,dc,dz,...) end
            local pos,sz,filled,corner=...; d.Position=pos; d.Size=sz; d.Filled=filled
            if corner then d.Corner=corner end
        elseif dt=='text' then
            if not d then self._drawings[id]=Drawing.new('Text'); return self:_Draw(id,dt,dc,dz,...) end
            local pos,content,outline,align,sz,face=...
            d.Center=(align=='center'); d.Position=pos
            d.Text=content; d.Outline=outline
            d.Font=face or self._font_face; d.Size=sz or self._font_size
        elseif dt=='line' then
            if not d then self._drawings[id]=Drawing.new('Line'); return self:_Draw(id,dt,dc,dz,...) end
            local fr,to,th=...; d.From=fr; d.To=to; d.Thickness=th or 1
        elseif dt=='triangle' then
            if not d then self._drawings[id]=Drawing.new('Triangle'); return self:_Draw(id,dt,dc,dz,...) end
            local f,a,b,c=...; d.Filled=f; d.PointA=a; d.PointB=b; d.PointC=c
        elseif dt=='circle' then
            if not d then self._drawings[id]=Drawing.new('Circle'); return self:_Draw(id,dt,dc,dz,...) end
            local pos,r,filled=...; d.Position=pos; d.Radius=r; d.Filled=filled
        elseif dt=='gradient' then
            local args={...}
            if #args==4 then
                local fc=args[4]; local tc=self._theming.crust
                table.insert(args,Color3.new(lerp(fc.R,tc.R,.5),lerp(fc.G,tc.G,.5),lerp(fc.B,tc.B,.5)))
            end
            local dir,orig,sz=args[1],args[2],args[3]
            local ns=(#args-3)-1; local lod=22
            for i=4,#args-1 do
                local cc,nc=args[i],args[i+1]
                local slx=sz.x/ns; local sly=sz.y/ns
                for j=1,lod do
                    local t2=(j-1)/(lod-1)
                    local tc2=Color3.new(lerp(cc.R,nc.R,t2),lerp(cc.G,nc.G,t2),lerp(cc.B,nc.B,t2))
                    local ta=lerp(cc.A or 1,nc.A or 1,t2)
                    local sp,ss
                    if dir=='horizontal' then ss=Vector2.new(slx/lod,sz.y); sp=Vector2.new(orig.x+(i-4)*slx+(j-1)*ss.x,orig.y)
                    elseif dir=='vertical' then ss=Vector2.new(sz.x,sly/lod); sp=Vector2.new(orig.x,orig.y+(i-4)*sly+(j-1)*ss.y) end
                    local sid=id..'_'..tostring(i)..'_'..tostring(j)
                    self:_Draw(sid,'rect',tc2,dz,sp,ss,true); self:_SetOpacity(sid,ta)
                end
            end
            return
        end
        d.Color=dc; d.ZIndex=dz; d.Visible=true
    end

    function UILib:_RemoveDraw(id)
        local d=self._drawings[id]; if d then d:Remove(); self._drawings[id]=nil end
    end
    function UILib:_Undraw(id)        local d=self._drawings[id]; if d then d.Visible=false end end
    function UILib:_SetOpacity(id,op) local d=self._drawings[id]; if d then d.Transparency=op end end

    -- Collect keys first to avoid mutating during iteration
    function UILib:_RemoveDrawStartsWith(id)
        local keys={}
        for n in pairs(self._drawings) do if n:sub(1,#id)==id then keys[#keys+1]=n end end
        for _,n in ipairs(keys) do self:_RemoveDraw(n) end
    end
    function UILib:_UndrawStartsWith(id)
        for n in pairs(self._drawings) do if n:sub(1,#id)==id then self:_Undraw(n) end end
    end
    function UILib:_SetOpacityStartsWith(id,op)
        for n in pairs(self._drawings) do if n:sub(1,#id)==id then self:_SetOpacity(n,op) end end
    end
    function UILib:_FullWipe()
        for _,d in pairs(self._drawings) do pcall(function() d:Remove() end) end
        self._drawings={}
    end
end

-- ── Spawners ──────────────────────────────────────────────────────────────────
do
    function UILib:_SpawnColorpicker(pos,label,val,cb)
        self:_RemoveColorpicker()
        local h,s,v=0,0,0
        if val then h,s,v=rgbToHsv(val.R,val.G,val.B) end
        self._active_colorpicker={position=pos or Vector2.new(self.x+self.w+self._padding,self.y),label=label,callback=cb,_h=h,_s=s,_v=v,_spawned_at=os.clock()}
    end
    function UILib:_RemoveColorpicker()
        self._active_colorpicker=nil; self:_RemoveDrawStartsWith('cp_')
    end
    function UILib:_SpawnDropdown(pos,width,val,choices,multi,cb)
        self:_RemoveDropdown()
        self._active_dropdown={position=pos,width=width,value=val,choices=choices,multi=multi,callback=cb,_spawned_at=os.clock(),_anim=0}
    end
    function UILib:_RemoveDropdown()
        self._active_dropdown=nil; self:_RemoveDrawStartsWith('dd_')
    end
end

-- ── Item constructors ─────────────────────────────────────────────────────────
do
    function UILib:_Toggle(tN,sN,label,val,cb,unsafe,tooltip)
        local id=#self._tree[tN]._items[sN]._items+1
        table.insert(self._tree[tN]._items[sN]._items,{type_='toggle',label=label,value=val,callback=cb,unsafe=unsafe or false,tooltip=tooltip})
        local ak=tN..sN..tostring(id); self._toggle_anim[ak]=val and 1 or 0
        return {
            Set=function(_,v)
                self._tree[tN]._items[sN]._items[id].value=v
                if self._tree[tN]._items[sN]._items[id].callback then self._tree[tN]._items[sN]._items[id].callback(v) end
            end,
            AddKeybind=function(_,kv,mode,cc2,kcb)
                local kb={value=kv,callback=kcb,mode=mode or 'Hold',canChange=cc2 or true,_listening=false,_listening_start=0}
                self._tree[tN]._items[sN]._items[id].keybind=kb
                return{Set=function(_,nv,nm)
                    local m=nm or self._tree[tN]._items[sN]._items[id].keybind.mode
                    self._tree[tN]._items[sN]._items[id].keybind.value=nv
                    self._tree[tN]._items[sN]._items[id].keybind.mode=m
                    if self._tree[tN]._items[sN]._items[id].keybind.callback then self._tree[tN]._items[sN]._items[id].keybind.callback(nv,m) end
                end}
            end,
            AddColorpicker=function(_,lbl,v2,ow,c2)
                local cp2={label=lbl,value=v2 or self._theming.accent,overwrite=ow,callback=c2}
                self._tree[tN]._items[sN]._items[id].colorpicker=cp2
                return{Set=function(_,nv)
                    self._tree[tN]._items[sN]._items[id].colorpicker.value=nv
                    if self._tree[tN]._items[sN]._items[id].colorpicker.callback then self._tree[tN]._items[sN]._items[id].colorpicker.callback(nv) end
                end}
            end
        }
    end

    function UILib:_Slider(tN,sN,label,val,step,mn,mx,sfx,cb)
        local id=#self._tree[tN]._items[sN]._items+1
        table.insert(self._tree[tN]._items[sN]._items,{type_='slider',label=label,value=val,step=step,min=mn,max=mx,suffix=sfx or '',callback=cb})
        return{Set=function(_,nv)
            self._tree[tN]._items[sN]._items[id].value=nv
            if self._tree[tN]._items[sN]._items[id].callback then self._tree[tN]._items[sN]._items[id].callback(nv) end
        end}
    end

    function UILib:_Dropdown(tN,sN,label,val,choices,multi,cb)
        local id=#self._tree[tN]._items[sN]._items+1
        table.insert(self._tree[tN]._items[sN]._items,{type_='dropdown',label=label,value=val,choices=choices,multi=multi,callback=cb})
        return{
            Set=function(_,nv)
                self._tree[tN]._items[sN]._items[id].value=nv
                if self._tree[tN]._items[sN]._items[id].callback then self._tree[tN]._items[sN]._items[id].callback(nv) end
            end,
            UpdateChoices=function(_,nc) self._tree[tN]._items[sN]._items[id].choices=nc end
        }
    end

    function UILib:_Button(tN,sN,label,cb)
        table.insert(self._tree[tN]._items[sN]._items,{type_='button',label=label,callback=cb}); return{}
    end

    function UILib:_Textbox(tN,sN,label,val,cb)
        local id=#self._tree[tN]._items[sN]._items+1
        table.insert(self._tree[tN]._items[sN]._items,{type_='textbox',label=label,value=val,callback=cb})
        return{Set=function(_,nv)
            self._tree[tN]._items[sN]._items[id].value=nv
            if self._tree[tN]._items[sN]._items[id].callback then self._tree[tN]._items[sN]._items[id].callback(nv) end
        end}
    end

    function UILib:_Section(tN,sN)
        self._tree[tN]._items[sN]={_items={}}
        return{
            Toggle  =function(_,...) return self:_Toggle(tN,sN,...) end,
            Slider  =function(_,...) return self:_Slider(tN,sN,...) end,
            Dropdown=function(_,...) return self:_Dropdown(tN,sN,...) end,
            Button  =function(_,...) return self:_Button(tN,sN,...) end,
            Textbox =function(_,...) return self:_Textbox(tN,sN,...) end,
        }
    end
end

-- ── Public API ────────────────────────────────────────────────────────────────
do
    function UILib:GetMenuSize()          return Vector2.new(self.w,self.h) end
    function UILib:SetWatermarkEnabled(v) self._watermark_enabled=v end
    function UILib:SetMenuTitle(t)        self.title=t; self._custom_title=t end
    function UILib:SetMenuPosition(p)     self.x=p.x or self.x; self.y=p.y or self.y end
    function UILib:SetMenuSize(s)         self.w=s.x or self.w; self.h=s.y or self.h end
    function UILib:CenterMenu()
        local ss=self:_GetScreenSize(); local ms=self:GetMenuSize()
        self:SetMenuPosition(Vector2.new(ss.x/2-ms.x/2,ss.y/2-ms.y/2))
    end
    function UILib:Notification(text,time)
        -- No pattern manipulation - just store as-is, use only ASCII-safe chars in messages
        table.insert(self._notifications,{text=tostring(text),time=time,_id=self._notifications_spawned,_spawned_at=os.clock()})
        self._notifications_spawned=self._notifications_spawned+1
    end
    function UILib:Tab(tabName)
        self._tree[tabName]={_items={}}
        -- Insert before Settings (last slot). On first call _tab_order is empty so just append.
        table.insert(self._tab_order, tabName)
        if not self._open_tab then self._open_tab=tabName; self._tab_fade=1 end
        return{Section=function(_,sn) return self:_Section(tabName,sn) end}
    end
    function UILib:RegisterActivity(a)
        local id=#self._activities+1; self._activities[id]=a
        return{Remove=function(_) self._activities[id]=nil end}
    end
    function UILib:Unload()
        -- Only set the flag here. _FullWipe is called by the script loop
        -- AFTER Step() returns cleanly, so no drawings remain on screen.
        self._unloaded=true
    end

    function UILib:CreateSettingsTab(customName)
        local st=self:Tab(customName or 'Settings')
        -- Move Settings to the end so it always renders on the right
        local name=customName or 'Settings'
        for i,n in ipairs(self._tab_order) do
            if n==name then table.remove(self._tab_order,i); break end
        end
        table.insert(self._tab_order, name)
        local ms=st:Section('Menu')
        local mk=ms:Toggle('Custom Menu Key',self._overwrite_menu_key,function(v) self._overwrite_menu_key=v end)
        mk:AddKeybind(self._menu_key,'Hold',false,function(v) self._menu_key=self:_KeyIDToName(v) end)
        ms:Toggle('Watermark',true,function(v) self:SetWatermarkEnabled(v) end)
        ms:Toggle('Custom watermark label',self._custom_title_enabled,function(v) self._custom_title_enabled=v end)
        self._custom_title=self.title
        ms:Textbox('Watermark text',self.title,function(v) self._custom_title=v end)
        local ts=st:Section('Theme')
        ts:Dropdown('Theme',{self._theme_name},{'Light','Dark','Sequoia'},false,function(v)
            if v and v[1] then self:_ApplyTheme(v[1]) end
        end)
        return st,ms,ts
    end
end

-- ── STEP ──────────────────────────────────────────────────────────────────────
function UILib:Step()
    if self._unloaded then return end

    local T=self._theming; local CR=self._corner; local PAD=self._padding
    local KB_W=self._KB_W

    -- ── Delta-time (FPS-independent, capped at 20fps floor) ──────────────
    local now=os.clock()
    local dt=math.min(now-self._last_step_time, 0.05)
    if self._last_step_time==0 then dt=0.016 end
    self._last_step_time=now
    -- dlp: converts a 60fps-tuned lerp factor to dt-scaled equivalent
    local function dlp(base) return 1-(1-base)^(dt*60) end

    -- ── Input polling ─────────────────────────────────────────────────────
    setrobloxinput(not self._menu_open)
    for kc,id2 in pairs(self._inputs) do
        local hit=iskeypressed(id2.id)
        if isrbxactive() and hit then
            self._inputs[kc].click=(not id2.held and not id2.click)
            self._inputs[kc].held=true
        else self._inputs[kc].click=false; self._inputs[kc].held=false end
    end

    local clickFrame = self:_IsKeyPressed('m1')
    local mouseHeld  = self:_IsKeyHeld('m1')
    local ctxFrame   = self:_IsKeyPressed('m2')
    local menuKey    = self:_IsKeyPressed(self._overwrite_menu_key and self._menu_key or 'f2')

    -- realClick: true only when m1 clicked AND no other key is simultaneously held.
    -- When Auto Green fires mouse1press(), the activator key (e.g. C) is still
    -- held on the same frame as m1 fires. A real mouse click has no keyboard key
    -- held alongside it, so we use this to distinguish synthetic from real clicks.
    local anyKbHeld=false
    for kn,k in pairs(self._inputs) do
        if kn~='m1' and kn~='m2' and kn~='mb' and k.held then anyKbHeld=true; break end
    end
    local realClick = clickFrame and not anyKbHeld

    if menuKey then
        self._menu_open=not self._menu_open
        if not self._menu_open then
            self:_UndrawStartsWith('menu_sec_')
            self:_RemoveDrawStartsWith('menu_title')
            self:_RemoveDrawStartsWith('menu_tab_')
            self:_RemoveDropdown()
            self:_RemoveColorpicker()
            self:Notification('Hidden - press F2 to show again',5)
        end
    end

    -- ── Mac-style close: slide down + fade ───────────────────────────────
    local targetScale=self._menu_open and 1 or 0
    self._menu_scale=lerp(self._menu_scale, targetScale, dlp(0.10))
    local sc=self._menu_scale  -- 0..1 raw

    if not self._menu_open and sc<0.015 then
        if not self._closed_wiped then
            self:_RemoveDrawStartsWith('menu_')
            self:_RemoveDrawStartsWith('mac_')
            self._closed_wiped=true
        end
    else
        self._closed_wiped=false
    end

    -- Drag
    if self._menu_open and mouseHeld and self._menu_drag then
        local mp=self:_GetMousePos(); self.x=mp.x-self._menu_drag.x; self.y=mp.y-self._menu_drag.y
    elseif not mouseHeld then self._menu_drag=nil end

    -- ── Watermark ─────────────────────────────────────────────────────────
    local ss=self:_GetScreenSize()
    local menuTitle=self._custom_title_enabled and self._custom_title or self.title
    local wtTxtSz=self:_GetTextBounds(menuTitle)
    local wtH=wtTxtSz.y+PAD; local wtW=wtTxtSz.x+PAD*2+10
    local wtPos=Vector2.new(ss.x-wtW-16,16)
    if self._watermark_enabled then
        self:_Draw('wm_sh','rect',T.shadow,98,wtPos+Vector2.new(2,3),Vector2.new(wtW,wtH),true,CR); self:_SetOpacity('wm_sh',0.20)
        self:_Draw('wm_body','rect',T.surface0,99,wtPos,Vector2.new(wtW,wtH),true,CR)
        self:_Draw('wm_brd','rect',T.border1,100,wtPos,Vector2.new(wtW,wtH),false,CR)
        self:_Draw('wm_dot','circle',T.accent,101,wtPos+Vector2.new(PAD+1,wtH/2),3,true)
        self:_Draw('wm_txt','text',T.text,101,wtPos+Vector2.new(PAD+8,(wtH-self._font_size)/2+1),menuTitle,false)
    else self:_UndrawStartsWith('wm_') end

    -- ── Notifications ─────────────────────────────────────────────────────
    local notifY=16+wtH+8
    for ni=#self._notifications,1,-1 do
        local notif=self._notifications[ni]
        local shouldFade=os.clock()>notif._spawned_at+notif.time
        local t=math.max(0,math.min(notif._spawned_at-os.clock()+(shouldFade and notif.time+1 or 1),1))
        local fade=math.abs((shouldFade and 0 or 1)-(t*t*(3-2*t)))
        local nid='notif_'..notif._id
        local txtSz=self:_GetTextBounds(notif.text)
        local nW=txtSz.x+PAD*2+6; local nH=txtSz.y+PAD*1.5
        local slideX=(nW+40)*(1-easeOut(fade))
        local nPos=Vector2.new(ss.x-nW-16+slideX,notifY)
        local alpha=math.max(0,math.min(fade,1))
        self:_Draw(nid..'_sh','rect',T.shadow,103,nPos+Vector2.new(2,4),Vector2.new(nW,nH),true,CR+2)
        self:_Draw(nid..'_body','rect',T.surface0,104,nPos,Vector2.new(nW,nH),true,CR+2)
        self:_Draw(nid..'_brd','rect',T.border1,105,nPos,Vector2.new(nW,nH),false,CR+2)
        self:_Draw(nid..'_txt','text',T.text,105,nPos+Vector2.new(PAD,(nH-self._font_size)/2+1),notif.text,false)
        self:_SetOpacity(nid..'_sh',0.15*alpha)
        self:_SetOpacity(nid..'_body',alpha)
        self:_SetOpacity(nid..'_brd',alpha)
        self:_SetOpacity(nid..'_txt',alpha)
        notifY=notifY+(nH+6)*fade
        if os.clock()-1>notif._spawned_at+notif.time then
            self:_RemoveDrawStartsWith(nid); table.remove(self._notifications,ni)
        end
    end

    -- ── Tooltip (0.08s delay) ─────────────────────────────────────────────
    if self._tooltip then
        local tt=self._tooltip
        tt.timer=(tt.timer or 0)+dt
        if tt.timer>0.08 then
            local ttTxtSz=self:_GetTextBounds(tt.text)
            local ttW=ttTxtSz.x+PAD*1.5; local ttH=ttTxtSz.y+PAD*0.8
            local mp=self:_GetMousePos(); local ttPos=Vector2.new(mp.x+10,mp.y-ttH-6)
            self:_Draw('tooltip_sh','rect',T.shadow,999,ttPos+Vector2.new(1,2),Vector2.new(ttW,ttH),true,6); self:_SetOpacity('tooltip_sh',0.18)
            self:_Draw('tooltip_body','rect',T.surface0,1000,ttPos,Vector2.new(ttW,ttH),true,6)
            self:_Draw('tooltip_brd','rect',T.border1,1001,ttPos,Vector2.new(ttW,ttH),false,6)
            self:_Draw('tooltip_txt','text',T.text,1001,ttPos+Vector2.new(PAD*0.75,(ttH-self._font_size)/2+1),tt.text,false)
        else self:_UndrawStartsWith('tooltip_') end
    else self:_UndrawStartsWith('tooltip_') end

    if sc<=0.015 then return end

    -- ── Window geometry: FIXED position, no scOff drift ──────────────────
    -- All child elements anchor to self.x/self.y always.
    -- Animation: opacity + downward slide ONLY on window chrome rectangles.
    local wx=self.x; local wy=self.y
    local ww=self.w; local wh=self.h
    local TBAH=self:_GetTextBounds(menuTitle).y+PAD*2+4

    -- Mac minimize: slide window down while fading
    local slideY=(1-easeOut(sc))*50  -- 0 when open, 50px down when closed
    local winOp=easeOut(sc)          -- fade 0..1

    -- Shadows
    self:_Draw('menu_sh_1','rect',T.shadow,0,Vector2.new(wx-1,wy+slideY+3),Vector2.new(ww+2,wh),true,CR+1); self:_SetOpacity('menu_sh_1',0.12*winOp)
    self:_Draw('menu_sh_2','rect',T.shadow,0,Vector2.new(wx-3,wy+slideY+6),Vector2.new(ww+6,wh),true,CR+3); self:_SetOpacity('menu_sh_2',0.06*winOp)

    -- Window body + chrome: all use wy+slideY so they slide together
    self:_Draw('menu_body','rect',T.body,1,Vector2.new(wx,wy+slideY),Vector2.new(ww,wh),true,CR); self:_SetOpacity('menu_body',winOp)
    self:_Draw('menu_obrd','rect',T.crust,2,Vector2.new(wx,wy+slideY),Vector2.new(ww,wh),false,CR); self:_SetOpacity('menu_obrd',winOp)
    self:_Draw('menu_tbar','rect',T.surface0,2,Vector2.new(wx+1,wy+slideY+1),Vector2.new(ww-2,TBAH),true,CR-1); self:_SetOpacity('menu_tbar',winOp)
    self:_Draw('menu_tbarsep','rect',T.border1,3,Vector2.new(wx+1,wy+slideY+TBAH),Vector2.new(ww-2,1),true); self:_SetOpacity('menu_tbarsep',winOp)

    -- Traffic lights: anchored to window top-left, constant size (no drift)
    local dotY=wy+slideY+TBAH/2; local dot1X=wx+16; local DOT_R=6
    self:_Draw('mac_r','circle',MAC_RED,4,Vector2.new(dot1X,dotY),DOT_R,true); self:_SetOpacity('mac_r',winOp)
    self:_Draw('mac_y','circle',MAC_YEL,4,Vector2.new(dot1X+20,dotY),DOT_R,true); self:_SetOpacity('mac_y',winOp)
    self:_Draw('mac_g','circle',MAC_GRN,4,Vector2.new(dot1X+40,dotY),DOT_R,true); self:_SetOpacity('mac_g',winOp)
    self:_Draw('mac_rb','circle',MAC_RED_B,4,Vector2.new(dot1X,dotY),DOT_R,false); self:_SetOpacity('mac_rb',winOp)
    self:_Draw('mac_yb','circle',MAC_YEL_B,4,Vector2.new(dot1X+20,dotY),DOT_R,false); self:_SetOpacity('mac_yb',winOp)
    self:_Draw('mac_gb','circle',MAC_GRN_B,4,Vector2.new(dot1X+40,dotY),DOT_R,false); self:_SetOpacity('mac_gb',winOp)

    -- Red dot close: use realClick to prevent synthetic trigger from keyboard
    if realClick and self:_IsMouseWithinBounds(Vector2.new(dot1X-DOT_R,dotY-DOT_R),Vector2.new(DOT_R*2,DOT_R*2)) then
        self._menu_open=false
        self:_UndrawStartsWith('menu_sec_')
        self:_RemoveDrawStartsWith('menu_title')
        self:_RemoveDrawStartsWith('menu_tab_')
        self:_RemoveDropdown(); self:_RemoveColorpicker()
        self:Notification('Hidden - press F2 to show again',5)
        clickFrame=false; realClick=false
    end

    -- Title: hidden during close animation to prevent floating text
    if self._menu_open and sc>0.5 then
        self:_Draw('menu_title','text',T.text,4,Vector2.new(wx+ww/2,wy+slideY+TBAH/2),menuTitle,false,'center')
    else
        self:_Undraw('menu_title')
    end

    -- Content area: strictly anchored to self.x/self.y — NO slideY
    -- slideY only affects the visual chrome rectangles above, never the content
    local bcPos=Vector2.new(wx+1,wy+TBAH+1)
    local bcSize=Vector2.new(ww-2,wh-TBAH-2)

    -- ── Dropdown ──────────────────────────────────────────────────────────
    local dd=self._active_dropdown
    if dd then
        dd._anim=lerp(dd._anim or 0,1,dlp(0.14))
        local ddA=dd._anim
        local ddO=dd.position
        local choiceH=self._font_size+9
        local panelW=dd.width+PAD*2; local panelH=#dd.choices*choiceH+PAD
        self:_Draw('dd_sh','rect',T.shadow,508,ddO+Vector2.new(2,4),Vector2.new(panelW,panelH),true,8); self:_SetOpacity('dd_sh',0.12*ddA)
        self:_Draw('dd_body','rect',T.surface0,509,ddO,Vector2.new(panelW,panelH),true,8); self:_SetOpacity('dd_body',ddA)
        self:_Draw('dd_brd','rect',T.border1,510,ddO,Vector2.new(panelW,panelH),false,8); self:_SetOpacity('dd_brd',ddA)
        for i,choice in ipairs(dd.choices) do
            local found=table.find(dd.value,choice)
            local cO=Vector2.new(ddO.x+PAD,ddO.y+PAD/2+(i-1)*choiceH)
            local cSz=Vector2.new(dd.width,choiceH)
            local hover=self:_IsMouseWithinBounds(cO,cSz)
            if hover then
                self:_Draw('dd_hov_'..i,'rect',lerpC(T.surface0,T.accent,0.18),511,cO+Vector2.new(2,1),cSz-Vector2.new(4,2),true,4)
            else self:_Undraw('dd_hov_'..i) end
            local cc=hover and T.accent or (found and T.accent or T.text)
            self:_Draw('dd_ch_'..i,'text',cc,512,cO+Vector2.new(8,4),choice,false,nil,12)
            if hover and clickFrame then
                if dd.multi then
                    local fi=table.find(dd.value,choice)
                    if fi then table.remove(dd.value,fi) else table.insert(dd.value,choice) end
                else dd.value={choice} end
                if dd.callback then dd.callback(dd.value) end
                if not dd.multi then self:_RemoveDropdown() end
                clickFrame=false; break
            end
        end
        if clickFrame then self:_RemoveDropdown(); clickFrame=false end
    else self:_UndrawStartsWith('dd_') end

    -- Colorpicker
    local cp=self._active_colorpicker
    if cp then
        local cpf=clamp((os.clock()-cp._spawned_at)/0.2,0,1)
        local shouldCancel=true; local cpSz=Vector2.new(200,205); local cpO=cp.position
        local cpTsz=self:_GetTextBounds(cp.label)
        self:_Draw('cp_sh','rect',T.shadow,98,cpO+Vector2.new(2,4),cpSz,true,CR); self:_SetOpacity('cp_sh',0.18*cpf)
        self:_Draw('cp_body','rect',T.surface0,99,cpO,cpSz,true,CR); self:_SetOpacity('cp_body',cpf)
        self:_Draw('cp_brd','rect',T.border1,100,cpO,cpSz,false,CR); self:_SetOpacity('cp_brd',cpf)
        self:_Draw('cp_title','text',T.text,101,cpO+Vector2.new(PAD,PAD+1),cp.label,false)
        local ppPos=cpO+Vector2.new(PAD+2,PAD+cpTsz.y+6); local ppSz=cpSz-Vector2.new(PAD*2+4,PAD*3+cpTsz.y)
        self:_Draw('cp_bi','rect',T.border1,100,ppPos-Vector2.new(1,1),ppSz+Vector2.new(2,2),false,4)
        self:_Draw('cp_bc','rect',T.body,102,ppPos,ppSz,true,4)
        local mp2=self:_GetMousePos()
        local pSz=ppSz-Vector2.new(PAD*2,PAD*2); local hSz=Vector2.new(pSz.x,10)
        pSz=pSz-Vector2.new(0,hSz.y+PAD)
        local pPos=ppPos+Vector2.new(PAD,PAD); local hPos=pPos+Vector2.new(0,pSz.y+PAD)
        if self:_IsMouseWithinBounds(hPos,hSz) and mouseHeld then cp._h=clamp((mp2.x-hPos.x)/hSz.x,0,1); shouldCancel=false end
        if self:_IsMouseWithinBounds(pPos,pSz) and mouseHeld then
            cp._s=clamp((mp2.x-pPos.x)/pSz.x,0,1); cp._v=1-clamp((mp2.y-pPos.y)/pSz.y,0,1); shouldCancel=false
        end
        local hueC=Color3.fromHSV(cp._h,1,1)
        self:_Draw('cp_pcol','gradient',nil,103,'horizontal',pPos,pSz,Color3.fromRGB(255,255,255),hueC)
        self:_Draw('cp_pfade','gradient',nil,104,'vertical',pPos,pSz,{R=0,G=0,B=0,A=0},{R=0,G=0,B=0,A=1})
        self:_Draw('cp_hue','gradient',nil,104,'horizontal',hPos,hSz,
            Color3.fromRGB(255,0,0),Color3.fromRGB(255,255,0),Color3.fromRGB(0,255,0),
            Color3.fromRGB(0,255,255),Color3.fromRGB(0,0,255),Color3.fromRGB(255,0,255),Color3.fromRGB(255,0,0))
        local newC=Color3.fromHSV(cp._h,cp._s,cp._v)
        if cp.callback then cp.callback(newC) end
        if clickFrame and shouldCancel then self:_RemoveColorpicker() end
        clickFrame=false
    end

    -- ── Tab bar ───────────────────────────────────────────────────────────
    local tabCount=#self._tab_order
    local TAB_PAD=6
    local tbOrig=bcPos+Vector2.new(TAB_PAD,TAB_PAD)
    local tbW=bcSize.x-TAB_PAD*2; local tabW=tbW/tabCount
    self:_Draw('menu_tbar_bg','rect',T.surface1,9,tbOrig,Vector2.new(tbW,self._tab_h),true,CR); self:_SetOpacity('menu_tbar_bg',winOp)
    self:_Draw('menu_tbar_brd','rect',T.border1,10,tbOrig,Vector2.new(tbW,self._tab_h),false,CR); self:_SetOpacity('menu_tbar_brd',winOp)

    -- Tab crossfade fast (~0.12s): dlp(0.15)
    if self._tab_changing then
        self._tab_fade=lerp(self._tab_fade,0,dlp(0.15))
        if self._tab_fade<0.04 then
            self:_UndrawStartsWith('menu_sec_')
            self._open_tab=self._next_tab; self._tab_changing=false; self._tab_fade=0
        end
    else
        self._tab_fade=lerp(self._tab_fade,1,dlp(0.15))
    end
    local cardAlpha=easeOut(self._tab_fade)

    local tabIter=0; local nextTooltip=nil

    for _,tabName in ipairs(self._tab_order) do
        local tabContent=self._tree[tabName]
        if tabContent then
        local tdid='menu_tab_'..tostring(tabIter)
        local tabPos=tbOrig+Vector2.new(tabW*tabIter,0); local tabSz=Vector2.new(tabW,self._tab_h)
        local isOpen=self._open_tab==tabName

        -- Show tabs only when fully open (sc>=0.99), hide instantly when closing
        if self._menu_open and sc > 0.99 and tabPos.X >= bcPos.X and tabPos.X + tabW <= bcPos.X + bcSize.x then
            if isOpen then
                self:_Draw(tdid..'_pill','rect',T.surface0,11,tabPos+Vector2.new(3,3),tabSz-Vector2.new(6,6),true,CR-2)
                self:_Draw(tdid..'_pillb','rect',T.border0,12,tabPos+Vector2.new(3,3),tabSz-Vector2.new(6,6),false,CR-2)
            else self:_UndrawStartsWith(tdid..'_pill') end
            if tabIter~=tabCount-1 and not isOpen then
                self:_Draw(tdid..'_div','rect',T.border1,11,tabPos+Vector2.new(tabW,self._tab_h*0.2),Vector2.new(1,self._tab_h*0.6),true)
            else self:_Undraw(tdid..'_div') end
            -- Tab text
            local textCol = isOpen and T.text or T.subtext
            self:_Draw(tdid..'_txt','text',textCol,13,tabPos+Vector2.new(tabW/2,self._tab_h/2),tabName,false,'center')
        else
            -- Hide tabs instantly when closing or not visible
            self:_UndrawStartsWith(tdid..'_pill')
            self:_Undraw(tdid..'_div')
            self:_Undraw(tdid..'_txt')
        end

        if not isOpen and clickFrame and self:_IsMouseWithinBounds(tabPos,tabSz) then
            if not self._tab_changing then
                self._tab_changing=true; self._next_tab=tabName; self._input_ctx=nil; self:_RemoveDropdown()
            end
        end

        local drawItems = self._menu_open and sc>0.5

        local secCount=getDictLen(tabContent._items)
        local secIter=0
        local secW=bcSize.x/2-PAD*1.5
        local totR=PAD*1.5; local totL=PAD*1.5
        local secTopY=bcPos.y+self._tab_h+TAB_PAD*2

        for secName,secContent in pairs(tabContent._items) do
            local sdid='menu_sec_'..tostring(secIter)..'_'..tostring(tabIter)
            local isLast=secIter>=secCount-2; local isMirror=secIter%2==1
            local sTsz=self:_GetTextBounds(secName)
            local sH=PAD+sTsz.y/2
            local sPos=isMirror
                and Vector2.new(bcPos.x+PAD*2+secW, secTopY+totR+sTsz.y/2)
                or  Vector2.new(bcPos.x+PAD,         secTopY+totL+sTsz.y/2)

            if isOpen and drawItems then
                self:_Draw(sdid..'_title','text',T.subtext,18,sPos+Vector2.new(PAD,-sTsz.y/2),secName,false)

                for siIter,sItem in ipairs(secContent._items) do
                    local siid=sdid..'_item_'..tostring(siIter)
                    local siOrig=Vector2.new(sPos.x+PAD,sPos.y+sH)
                    local iType=sItem.type_; local iVal=sItem.value; local iCb=sItem.callback
                    local ak=tabName..secName..tostring(siIter)

                    if iType=='toggle' then
                        local tgt=iVal and 1 or 0
                        local cur=lerp(self._toggle_anim[ak] or tgt,tgt,dlp(0.10))
                        self._toggle_anim[ak]=cur
                        local SW=34; local SH=self._font_size+2
                        local itemKB=sItem.keybind; local itemCP=sItem.colorpicker
                        local rightReserve=0

                        if itemKB then
                            rightReserve=KB_W+PAD
                            local kbName=(itemKB.value or '?'):upper()
                            local kbTxt=itemKB._listening and '...' or kbName
                            local kbFont=12
                            while kbFont>7 and self:_GetTextBounds(kbTxt,nil,kbFont).x>KB_W-6 do kbFont=kbFont-1 end
                            local kbOrig=Vector2.new(sPos.x+secW-KB_W-PAD,siOrig.y+(SH-self._font_size)/2)
                            local kbSz=Vector2.new(KB_W,self._font_size+2)
                            local hover=self:_IsMouseWithinBounds(kbOrig,kbSz)
                            local kbBg=hover and lerpC(T.surface1,T.accent,0.2) or T.surface1
                            -- Per-frame keybind activation: Toggle or Hold mode
                            if itemKB.value and not itemKB._listening then
                                local kbPressed=self:_IsKeyPressed(itemKB.value)
                                local kbHeld   =self:_IsKeyHeld(itemKB.value)
                                local mode=itemKB.mode or 'Toggle'
                                if mode=='Toggle' and kbPressed and sItem.value then
                                    -- Keybind in Toggle mode only fires when toggle is ON (turns it OFF)
                                    -- To turn ON: use the switch. To turn OFF quickly: use the keybind.
                                    local nv=false; sItem.value=nv; if iCb then iCb(nv) end
                                elseif mode=='Hold' then
                                    local nv=kbHeld; if nv~=sItem.value then sItem.value=nv; if iCb then iCb(nv) end end
                                elseif mode=='Always' then
                                    if not sItem.value then sItem.value=true; if iCb then iCb(true) end end
                                end
                            end
                            self:_Draw(siid..'_kbsh','rect',T.shadow,19,kbOrig+Vector2.new(1,2),kbSz,true,6); self:_SetOpacity(siid..'_kbsh',0.10)
                            self:_Draw(siid..'_kbbg','rect',kbBg,20,kbOrig,kbSz,true,6)
                            self:_Draw(siid..'_kbbrd','rect',itemKB._listening and T.accent or T.border1,21,kbOrig,kbSz,false,6)
                            self:_Draw(siid..'_kbtxt','text',itemKB.value and T.text or T.subtext,21,kbOrig+Vector2.new(KB_W/2,kbSz.y/2),kbTxt,false,'center',kbFont)
                            if hover then
                                -- KEYBIND FIX: only a realClick (no kb held) can open listening.
                                -- This blocks synthetic m1 from Auto Green's mouse1press().
                                if realClick then
                                    itemKB._listening=true
                                    itemKB._listening_start=os.clock()
                                    clickFrame=false; realClick=false
                                elseif ctxFrame and itemKB.canChange then
                                    self:_SpawnDropdown(self:_GetMousePos(),60,{itemKB.mode},{'Hold','Toggle','Always'},false,function(nv)
                                        itemKB.mode=nv[1]
                                        if itemKB.callback then itemKB.callback(self._inputs[itemKB.value] and self._inputs[itemKB.value].id or nil,nv[1]) end
                                    end); ctxFrame=false
                                end
                            end
                            if itemKB._listening then
                                local elapsed=os.clock()-itemKB._listening_start
                                if elapsed>0.15 then
                                    for kn,k in pairs(self._inputs) do
                                        if self:_IsKeyPressed(kn) then
                                            if kn=='m1' then
                                                -- Any m1 after debounce cancels (never binds to mouse)
                                                itemKB._listening=false
                                            else
                                                local nv=kn~='unbound' and kn
                                                if itemKB.callback and self._inputs[nv] then itemKB.callback(k.id,itemKB.mode) end
                                                itemKB.value=nv; itemKB._listening=false
                                            end
                                        end
                                    end
                                end
                            end
                        elseif itemCP then
                            local cpSzEl=Vector2.new(self._font_size*2,self._font_size)
                            local cpOEl=siOrig+Vector2.new(secW-PAD*2-cpSzEl.x)
                            rightReserve=cpSzEl.x+PAD*2
                            local hover=self:_IsMouseWithinBounds(cpOEl,cpSzEl)
                            if hover then
                                if clickFrame then
                                    self:_SpawnColorpicker(nil,itemCP.label,itemCP.value,function(nv) itemCP.value=nv; if itemCP.callback then itemCP.callback(nv) end end); clickFrame=false
                                elseif ctxFrame then
                                    self:_SpawnDropdown(self:_GetMousePos(),60,{},{'Copy','Paste'},false,function(nv)
                                        if nv[1]=='Copy' then self._copied_color=itemCP.value
                                        elseif nv[1]=='Paste' and self._copied_color then itemCP.value=self._copied_color; if itemCP.callback then itemCP.callback(self._copied_color) end
                                        else self:Notification('Nothing copied yet',4) end
                                    end); ctxFrame=false
                                end
                            end
                            self:_Draw(siid..'_cp','gradient',nil,20,'vertical',cpOEl+Vector2.new(1,1),cpSzEl-Vector2.new(2,2),itemCP.value)
                            self:_Draw(siid..'_cpb','rect',T.crust,21,cpOEl,cpSzEl,false,4)
                        end

                        local labelColor=sItem.unsafe and T.unsafe or (iVal and T.text or T.subtext)
                        if not itemCP or not itemCP.overwrite then
                            local hover=self:_IsMouseWithinBounds(siOrig,Vector2.new(SW,SH))
                            if hover and clickFrame then local nv=not iVal; sItem.value=nv; if iCb then iCb(nv) end; clickFrame=false end
                            local trkC=lerpC(T.surface1,T.accent,cur)
                            self:_Draw(siid..'_track','rect',trkC,20,siOrig,Vector2.new(SW,SH),true,SH/2)
                            self:_Draw(siid..'_trackb','rect',lerpC(T.border1,T.accent,cur),21,siOrig,Vector2.new(SW,SH),false,SH/2)
                            local kr=(SH/2)-1; local kx=siOrig.x+kr+1+(SW-SH)*cur; local ky=siOrig.y+SH/2
                            self:_Draw(siid..'_knobsh','circle',T.shadow,21,Vector2.new(kx,ky+1),kr,true); self:_SetOpacity(siid..'_knobsh',0.15)
                            self:_Draw(siid..'_knob','circle',T.surface0,22,Vector2.new(kx,ky),kr,true)
                        else labelColor=T.text end

                        local maxLblW=secW-SW-PAD*2-rightReserve
                        local lblStr=sItem.label; local truncated=false
                        while #lblStr>1 and self:_GetTextBounds(lblStr).x>maxLblW do lblStr=lblStr:sub(1,-2); truncated=true end
                        if truncated then lblStr=lblStr:sub(1,-2)..'..' end
                        local lblPos=siOrig+Vector2.new(SW+PAD,(SH-self._font_size)/2)
                        self:_Draw(siid..'_lbl','text',labelColor,20,lblPos,lblStr,false)
                        if truncated and self:_IsMouseWithinBounds(lblPos,self:_GetTextBounds(lblStr)) then
                            if self._tooltip and self._tooltip.key==siid then
                            else self._tooltip={key=siid,text=sItem.label,pos=self:_GetMousePos(),timer=0} end
                            nextTooltip=siid
                        end
                        sH=sH+SH+PAD

                    elseif iType=='slider' then
                        local lsz=self:_GetTextBounds(sItem.label)
                        local btnW=self._font_size
                        local trackX=siOrig.x+btnW+PAD
                        local trackW=secW-PAD*2-btnW*2-PAD*2
                        local slO=Vector2.new(trackX,siOrig.y+lsz.y+PAD)
                        local slSz=Vector2.new(trackW,6)
                        self:_Draw(siid..'_lbl','text',T.text,20,siOrig,sItem.label,false)
                        local nv=iVal
                        local hover=self:_IsMouseWithinBounds(slO-Vector2.new(4,8),slSz+Vector2.new(8,16))
                        if mouseHeld then
                            if hover and clickFrame then self._slider_drag=siid; clickFrame=false end
                            if self._slider_drag==siid then
                                local pct=clamp((self:_GetMousePos().x-slO.x)/slSz.x,0,1)
                                nv=sItem.min+(sItem.max-sItem.min)*pct
                                nv=math.floor((nv/sItem.step)+0.5)*sItem.step
                                nv=clamp(nv,sItem.min,sItem.max)
                            end
                        else self._slider_drag=nil end
                        local decCX=siOrig.x+btnW/2; local incCX=trackX+trackW+PAD+btnW/2
                        local btnCY=slO.y+slSz.y/2
                        local decHit=Vector2.new(siOrig.x,btnCY-btnW/2); local incHit=Vector2.new(trackX+trackW+PAD,btnCY-btnW/2)
                        local hitSz=Vector2.new(btnW,btnW)
                        self:_Draw(siid..'_dec','text',T.subtext,20,Vector2.new(decCX,btnCY),'-',false,'center')
                        self:_Draw(siid..'_inc','text',T.subtext,20,Vector2.new(incCX,btnCY),'+',false,'center')
                        if clickFrame then
                            if self:_IsMouseWithinBounds(decHit,hitSz) then nv=clamp(iVal-sItem.step,sItem.min,sItem.max); clickFrame=false
                            elseif self:_IsMouseWithinBounds(incHit,hitSz) then nv=clamp(iVal+sItem.step,sItem.min,sItem.max); clickFrame=false end
                        end
                        if nv~=iVal then sItem.value=nv; if iCb then iCb(nv) end end
                        local fp=clamp((iVal-sItem.min)/(sItem.max-sItem.min),0,1)
                        self:_Draw(siid..'_track','rect',T.surface1,20,slO,slSz,true,3)
                        self:_Draw(siid..'_tb','rect',T.border1,21,slO,slSz,false,3)
                        local fillW=math.max(0,slSz.x*fp-2)
                        self:_Draw(siid..'_fill','rect',T.accent,22,slO+Vector2.new(1,1),Vector2.new(fillW,slSz.y-2),true,3)
                        local thumbX=slO.x+slSz.x*fp; local thumbY=slO.y+slSz.y/2
                        self:_Draw(siid..'_thumb','circle',T.surface0,23,Vector2.new(thumbX,thumbY),5,true)
                        self:_Draw(siid..'_thumbb','circle',T.accent,24,Vector2.new(thumbX,thumbY),5,false)
                        local dv=fmtNum(iVal)..sItem.suffix
                        self:_Draw(siid..'_val','text',T.text,22,Vector2.new(thumbX,thumbY+12),dv,false,'center',11)
                        sH=sH+lsz.y+slSz.y+PAD*3+18

                    elseif iType=='dropdown' then
                        local lsz=self:_GetTextBounds(sItem.label)
                        local ep=self._font_size
                        local dO=Vector2.new(siOrig.x+ep+PAD,siOrig.y+lsz.y+PAD)
                        local dSz=Vector2.new(secW-ep*2-PAD*3,lsz.y+PAD)
                        local hover=self:_IsMouseWithinBounds(dO,dSz)
                        if clickFrame and hover then
                            if self._active_dropdown then self:_RemoveDropdown()
                            else self:_SpawnDropdown(Vector2.new(dO.x,dO.y+dSz.y),dSz.x,iVal,sItem.choices,sItem.multi,function(nv) sItem.value=nv; if iCb then iCb(nv) end end) end
                            clickFrame=false
                        end
                        local aak=siid..'_arw'
                        self._dd_arrow_anim[aak]=lerp(self._dd_arrow_anim[aak] or 0,self._active_dropdown and 1 or 0,dlp(0.14))
                        local at=self._dd_arrow_anim[aak]
                        local ax=dO.x+dSz.x-PAD-4; local ay=dO.y+dSz.y/2
                        local p1=Vector2.new(lerp(ax,ax,at),       lerp(ay-4,ay,at))
                        local p2=Vector2.new(lerp(ax+5,ax+2.5,at), lerp(ay,ay+4,at))
                        local p3=Vector2.new(lerp(ax,ax+5,at),     lerp(ay+4,ay,at))
                        local dBg=hover and lerpC(T.surface0,T.accent,0.06) or T.surface0
                        self:_Draw(siid..'_dsh','rect',T.shadow,19,dO+Vector2.new(1,2),dSz,true,6); self:_SetOpacity(siid..'_dsh',0.10)
                        self:_Draw(siid..'_dl','rect',dBg,20,dO,dSz,true,6)
                        self:_Draw(siid..'_db','rect',T.border1,21,dO,dSz,false,6)
                        self:_Draw(siid..'_da','triangle',T.subtext,21,true,p1,p2,p3)
                        local dv=table.concat(iVal,', ')
                        if self:_GetTextBounds(dv).x>dSz.x-PAD-14 then dv=tostring(#iVal)..' item'..( #iVal==1 and '' or 's') end
                        self:_Draw(siid..'_dv','text',T.text,21,dO+Vector2.new(6,self:_GetTextBounds(dv).y/2-1),dv,false)
                        self:_Draw(siid..'_dl2','text',T.text,20,siOrig+Vector2.new(PAD+ep,0),sItem.label,false)
                        sH=sH+lsz.y+dSz.y+PAD*3

                    elseif iType=='button' then
                        local lsz=self:_GetTextBounds(sItem.label)
                        local ep=self._font_size
                        local bO=Vector2.new(siOrig.x+ep+PAD,siOrig.y)
                        local bSz=Vector2.new(secW-ep*2-PAD*3,lsz.y+PAD)
                        local hover=self:_IsMouseWithinBounds(bO,bSz)
                        if mouseHeld then
                            if hover and clickFrame then self._slider_drag=siid; clickFrame=false; if iCb then iCb() end end
                        else self._slider_drag=nil end
                        local clicked=mouseHeld and self._slider_drag==siid
                        local bBg=clicked and T.accent or (hover and lerpC(T.surface0,T.accent,0.08) or T.surface0)
                        self:_Draw(siid..'_bsh','rect',T.shadow,19,bO+Vector2.new(1,2),bSz,true,6); self:_SetOpacity(siid..'_bsh',0.10)
                        self:_Draw(siid..'_bb','rect',bBg,20,bO,bSz,true,6)
                        self:_Draw(siid..'_bbd','rect',T.border1,21,bO,bSz,false,6)
                        self:_Draw(siid..'_bt','text',clicked and T.surface0 or T.text,21,bO+Vector2.new(bSz.x/2,bSz.y/2),sItem.label,false,'center')
                        sH=sH+bSz.y+PAD*2

                    elseif iType=='textbox' then
                        local tbO=siOrig; local tbSz=Vector2.new(secW-PAD*2,self._font_size+PAD)
                        local hover=self:_IsMouseWithinBounds(tbO,tbSz)
                        local isTyping=self._input_ctx==siid
                        local cursor=math.floor(os.clock()*2)%2==0 and '|' or ' '
                        local dv=isTyping and ((iVal or '')..cursor) or ((iVal and iVal~='' and iVal or sItem.label)..' ')
                        local vc=isTyping and T.text or ((iVal and iVal~='') and T.text or T.subtext)
                        if self:_GetTextBounds(dv).x>tbSz.x then
                            for i=1,#dv do local s2=dv:sub(i); if self:_GetTextBounds(s2).x<=tbSz.x-4 then dv=s2; break end end
                        end
                        local vsz=self:_GetTextBounds(dv)
                        if self:_IsKeyPressed('m1') then
                            if hover then self._input_ctx=siid; clickFrame=false
                            elseif isTyping then self._input_ctx=nil; self:_RemoveDropdown(); isTyping=false; clickFrame=false end
                        elseif ctxFrame and hover then
                            self:_SpawnDropdown(self:_GetMousePos(),60,{},{'Copy','Clear'},false,function(nv)
                                if nv[1]=='Copy' then setclipboard(tostring(iVal)); self:Notification('Copied',3)
                                elseif nv[1]=='Clear' then sItem.value=''; if sItem.callback then sItem.callback('') end end
                            end); ctxFrame=false
                        end
                        if isTyping then
                            local cm={space=' ',dash='-',colon=':',period='.',comma=',',slash='/',semicolon=';',quote='\'',leftbracket='[',rightbracket=']',backslash='\\',equals='=',minus='-'}
                            local sm={['1']='!',['2']='@',['3']='#',['4']='$',['5']='%',['6']='^',['7']='&',['8']='*',['9']='(',['0']=')',['-']='_',['=']='+',['[']='{',[']']='}',[';']=':',['\'']='"',[',']='<',['.']='>',['/']='?',['\\']='|'}
                            local nv=iVal or ''; local shift=self:_IsKeyHeld('lshift') or self:_IsKeyHeld('rshift')
                            for char in pairs(self._inputs) do
                                if self:_IsKeyPressed(char) then
                                    local mapped=cm[char] or char
                                    if mapped=='enter' then self._input_ctx=nil; break
                                    elseif mapped=='unbound' then nv=nv:sub(1,-2)
                                    elseif #mapped==1 then
                                        if shift and sm[mapped] then mapped=sm[mapped] elseif shift then mapped=mapped:upper() end
                                        nv=nv..mapped
                                    end
                                    if sItem.callback then sItem.callback(nv) end; sItem.value=nv
                                end
                            end
                        end
                        self:_Draw(siid..'_tbb','rect',isTyping and T.surface0 or T.surface1,20,tbO,tbSz,true,6)
                        self:_Draw(siid..'_tbbd','rect',isTyping and T.accent or T.border1,21,tbO,tbSz,false,6)
                        self:_Draw(siid..'_tbt','text',vc,21,tbO+Vector2.new(6,vsz.y/2-2),dv,false)
                        sH=sH+tbSz.y+PAD
                    end
                end -- items

                if isMirror then totR=totR+sH+sTsz.y/2 else totL=totL+sH+sTsz.y/2 end
                if isLast then
                    local avail=bcSize.y-self._tab_h-TAB_PAD*2-PAD
                    if isMirror then sH=avail-totR+sH else sH=avail-totL+sH end
                end

                self:_Draw(sdid..'_sh','rect',T.shadow,10,sPos+Vector2.new(2,3),Vector2.new(secW,sH),true,CR)
                self:_SetOpacity(sdid..'_sh',0.10*cardAlpha)
                self:_Draw(sdid..'_bg','rect',T.surface0,11,sPos,Vector2.new(secW,sH),true,CR)
                self:_SetOpacity(sdid..'_bg',cardAlpha)
                self:_Draw(sdid..'_brd','rect',T.border1,12,sPos,Vector2.new(secW,sH),false,CR)
                self:_SetOpacity(sdid..'_brd',cardAlpha)

                if isMirror then totR=totR+PAD else totL=totL+PAD end
            else
                self:_UndrawStartsWith(sdid)
            end
            secIter=secIter+1
        end
        end -- if tabContent
        tabIter=tabIter+1
    end

    if nextTooltip==nil and self._tooltip then self._tooltip=nil end

    -- Drag start: only real mouse clicks can initiate drag
    if realClick and not self._menu_drag and self:_IsMouseWithinBounds(Vector2.new(wx,wy),Vector2.new(ww,TBAH)) then
        local mp=self:_GetMousePos(); self._menu_drag=Vector2.new(mp.x-self.x,mp.y-self.y)
    end
end

function UILib:ShowDemoMenu()
    self:SetMenuSize(Vector2.new(420,500)); self:CenterMenu()
    local p=self:Tab('NBA'); local s=p:Section('Auto Shoot')
    local ag=s:Toggle('Auto Green',false,nil); ag:AddKeybind('c','Toggle',true)
    s:Slider('Release Delay',0.50,0.01,0.10,1.00,'s')
    local _,ms=self:CreateSettingsTab('Settings')
    ms:Button('Unload',function() self:Unload() end)
    self:Notification('@prodordie loaded',6); self:Notification('F2 to toggle',8)
    while true do self:Step(); task.wait() end
end

return UILib
